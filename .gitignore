# Dependencies
node_modules/

# Build output
mcp-server/dist/

# MLO reference material — sample data exports, file-format notes, the app's own
# form/string resources used as a schema reference, helper scripts, installer, and
# packaging tooling. Local-only (large/not needed to build).
sources/

# Temp exports
*.tmp
export_*.xml

# Backups and lock dirs made by the mlo-mcp write pipeline
*.ml.bak-*
*.ml.mcp-lock/

# mcp-cloud message log + state, and the reference client's cursor files
/messages/

# Legacy per-profile cloud state and timestamped debug captures
*.ml.mcp-cloud*/

# Local machine config (permissions, etc.)
.claude/settings.local.json

# Work-in-progress issues/specs (see docs/agents/issue-tracker.md)
.scratch/

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log

# Sensitive local HTTP interception captures
.mitmproxy/
