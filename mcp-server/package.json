{
  "name": "mlo-mcp",
  "version": "0.2.0",
  "description": "MCP server for MyLife Organized (MLO) desktop app",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:mlo": "vitest run --project mlo",
    "tool": "tsx scripts/run-tool.ts",
    "tools": "tsx scripts/tools.ts",
    "cloud": "tsx scripts/cloud-client.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-xml-parser": "^4.3.0",
    "fflate": "^0.8.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.10"
  }
}
